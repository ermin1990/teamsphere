{
  "build": {
    "builder": "dockerfile"
  },
  "environments": {
    "production": {
      "variables": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "LOG_CHANNEL": "stack",
        "LOG_LEVEL": "error",
        "DB_CONNECTION": "pgsql",
        "CACHE_DRIVER": "redis",
        "QUEUE_CONNECTION": "database",
        "SESSION_DRIVER": "redis",
        "MAIL_MAILER": "smtp"
      }
    }
  }
}