# Copy this to .env.production and fill values before deploying
APP_NAME=Teamsphere
APP_ENV=production
APP_KEY=base64:GENERATE_THIS
APP_DEBUG=0
APP_URL=http://your-domain-or-ip:3000

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=teamsphere
DB_USERNAME=teamsphere
DB_PASSWORD=secret

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=database

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null

# Set to true to run migrations automatically on start
RUN_MIGRATIONS=false
