<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>{{ $competition->name }} - Izvještaj</title>
    <style>
        body {
            font-family: 'DejaVu Sans', sans-serif;
            font-size: 10px;
            color: #1f2937;
